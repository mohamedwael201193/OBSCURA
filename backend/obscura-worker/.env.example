# obscura-worker environment variables
# Copy to .env and fill in SECRETS before running locally

# ── RPC ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<ALCHEMY_KEY>
INDEXER_GETLOGS_CHUNK_BLOCKS=10
INDEXER_GETLOGS_RETRIES=3
INDEXER_GETLOGS_RETRY_BASE_MS=1000
INDEXER_LIVE_POLL_MS=5000
INDEXER_LIVE_RETRY_MAX_MS=30000
INDEXER_STARTUP_RECENT_BLOCKS=5000
INDEXER_BACKGROUND_BACKFILL_DELAY_MS=15000
INDEXER_DISPATCH_RECOVERED_DUPLICATES=true
CREDIT_INDEXER_MARKETS=0x1Ec113297c7F9516A6604aa3b18C180559a6f551,0x269f59672F3fd7f95bF440941e618b54Ebc5717A,0xcf98d97934F37Ac9A05bc037437E43cb6788eC8b,0x0b645441D65A0CCb91A82b5a2eE3156C1c89207B,0x05e58B8D96Bbd752A72Fa02921A0eE31eCB9035d
CREDIT_INDEXER_VAULTS=0xCEBb042ae8FDE217a9FdE5b8a82E23827FdBB898,0xF508315bD4C5EC4c71C5E431AE972C0dC6B78Bbc
CREDIT_INDEXER_AUCTIONS=0x205FfC0A3b8207B645c1a6B1b4805eb3FfC828F0
CREDIT_INDEXER_SCORES=0xe5B0c6c06C0B1fd7d7CD5D2e93997693863d3D4D
REPUTATION_EVENTS_ENABLED=true
REPUTATION_BACKFILL_ON_START=true
REPUTATION_BACKFILL_LIMIT=500

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://quoovjkjwgtdqwdofubh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE  # Supabase → Project Settings → API → service_role

# ── Web Push ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://obscura-os-nine.vercel.app
VAPID_CONTACT_EMAIL=noreply@obscura.finance
VAPID_PUBLIC_KEY=BIgVcwUhCL93WVMnDdRT9KqySwDS4Sm9C-fSLg4dWJRdddSuLbyDv_M9R5FmDi2F8NwDuKuMtvNiZAwZQ0RH86o
VAPID_PRIVATE_KEY=PASTE_VAPID_PRIVATE_KEY_HERE        # Must match the public key — KEEP SECRET

# ── Credit Keeper — Chainlink Oracles (Arbitrum Sepolia) ─────────────────────
CHAINLINK_ETHUSD_ADAPTER=0xe3E388b421bfcF558FD46a18eE3b1c27aD1D36B3
CHAINLINK_USDCUSD_ADAPTER=0xc65e85926Cb29aaEC74f99cF1591CBa65daa2c4A

# ── Credit Keeper — Contract Addresses ───────────────────────────────────────
KEEPER_AUCTION=0x205FfC0A3b8207B645c1a6B1b4805eb3FfC828F0
KEEPER_MARKETS=0x1Ec113297c7F9516A6604aa3b18C180559a6f551,0x269f59672F3fd7f95bF440941e618b54Ebc5717A,0xcf98d97934F37Ac9A05bc037437E43cb6788eC8b,0x0b645441D65A0CCb91A82b5a2eE3156C1c89207B,0x05e58B8D96Bbd752A72Fa02921A0eE31eCB9035d

# ── Credit Keeper — Keeper Bot ────────────────────────────────────────────────
KEEPER_ENABLED=false                                  # Set true only when the keeper should share RPC quota with indexing
KEEPER_PRIVATE_KEY=                                    # Keeper EOA private key (0x...) — KEEP SECRET
KEEPER_DRY_RUN=true                                    # Set false in production to execute txs
KEEPER_POLL_MS=30000
KEEPER_HF_THRESHOLD_BPS=10000
KEEPER_BID_DISCOUNT_BPS=200
KEEPER_MAX_GAS_GWEI=2
