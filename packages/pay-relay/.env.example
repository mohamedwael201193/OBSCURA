# ERC-4337 bundler endpoint (Alchemy, Pimlico, or local)
# Example Alchemy: https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY/rpc
BUNDLER_URL=

# Paymaster address (informational only — used in /health response)
PAYMASTER_ADDRESS=

# Port (default 3701)
PORT=3701

# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:5173
